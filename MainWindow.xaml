<Window x:Class="Spotlight.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spotlight"
        Width="720"
        Height="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Topmost="True"
        Opacity="0">

    <Grid>

        <!-- GLASS PANEL -->
        <Border x:Name="Glass"
                Width="650"
                Height="320"
                CornerRadius="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="18">

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#66333333" Offset="0"/>
                    <GradientStop Color="#55333333" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Border.BorderBrush>
                <SolidColorBrush Color="#80FFFFFF"/>
            </Border.BorderBrush>

            <Border.BorderThickness>1</Border.BorderThickness>

            <Border.Effect>
                <DropShadowEffect BlurRadius="35"
                                  ShadowDepth="0"
                                  Opacity="0.4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- SEARCH BOX AREA -->
                <Grid Grid.Row="0">

                    <!-- Input -->
                    <TextBox x:Name="SearchBox"
                             FontSize="20"
                             Height="38"
                             VerticalContentAlignment="Center"
                             Foreground="White"
                             Background="Transparent"
                             BorderThickness="0"
                             CaretBrush="White"
                             TextChanged="SearchBox_TextChanged"/>

                    <!-- Placeholder -->
                    <TextBlock Text="Search apps..."
                               FontSize="20"
                               Foreground="#E6FFFFFF"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Margin="2,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <Trigger Property="IsVisible" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </Grid>

                <!-- RESULTS -->
                <ListBox x:Name="ResultsList"
                         Grid.Row="1"
                         Margin="0,12,0,0"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="White"
                         FontSize="16"
                         Height="240"
                         MouseDoubleClick="ResultsList_DoubleClick">

                    <!-- ITEM STYLE -->
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Background" Value="Transparent"/>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#33FFFFFF"/>
                                </Trigger>

                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#55FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <!-- ITEM TEMPLATE -->
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       FontSize="17"
                                       Foreground="#F5FFFFFF"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>

            </Grid>

        </Border>

    </Grid>
</Window>